{
  "name": "templateapp",
  "private": true,
  "version": "1.0.0",
  "description": "Starter monorepo: React/Vite frontend + Node/Apollo backend",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd app && npm run dev",
    "dev:backend": "cd api && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
